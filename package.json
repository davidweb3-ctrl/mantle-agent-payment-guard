{
  "name": "mantle-agent-payment-guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:contracts": "forge test",
    "deploy:mantle-sepolia": "forge create contracts/AgentPaymentGuard.sol:AgentPaymentGuard --rpc-url \"$MANTLE_SEPOLIA_RPC_URL\" --private-key \"$PRIVATE_KEY\" --broadcast",
    "deploy:pages": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "viem": "^2.43.0"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
